#!/usr/bin/env bash
# agent-coherence plugin: SessionStart hook shim.
#
# Ensures the local coordinator is running for this workspace. The Python
# coordinator handles fcntl-locked lazy spawn + race-safety + idle-shutdown +
# SQLite-WAL rehydration. This shim is intentionally thin.
#
# On v2.1.131, plugin hooks are *command-type* (per Phase E.0 probe 2A —
# CC's hooks.json schema validator rejects URLs containing env-var templates
# at load time, so HTTP-type with ${COHERENCE_PORT} is structurally infeasible).
# The hook-client reads .coherence/server.pid directly, so this shim does NOT
# need to propagate COHERENCE_PORT via $CLAUDE_ENV_FILE.
#
# Errors degrade gracefully: a missing library → no coordinator → hook
# handlers no-op silently per v0.1 warn-mode best-effort stance.

set -uo pipefail

# Locate the coordinator console script (installed by `pip install agent-coherence`)
if ! command -v agent-coherence-coordinator >/dev/null 2>&1; then
  echo "agent-coherence: coordinator console script not on PATH; install via 'pip install agent-coherence' to enable coherence detection. Hooks will no-op silently." >&2
  exit 0
fi

# Spawn or attach. The Python script writes <pid>\n<port>\n to .coherence/server.pid;
# the hook-client subsequently reads it to address the coordinator. We don't need
# to capture or propagate the port through env vars.
exec agent-coherence-coordinator --quiet
