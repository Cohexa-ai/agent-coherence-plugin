#!/usr/bin/env bash
# agent-coherence plugin: universal hook-client dispatch shim (zero-Python Unit 5).
#
# Hooks route through this ONE shim so the client selection is a single seam:
#   1. Node hook-client (dist/hook_client.js) — preferred. Uses ONLY node:
#      builtins (no node_modules), so it runs straight from the plugin's
#      shipped dist/ with no npm install and no Python. Backend-agnostic:
#      it POSTs to whichever coordinator holds .coherence/server.pid.
#   2. Python agent-coherence-hook-client — fallback for environments with
#      no `node` on PATH (a Python-backend user who never needed Node).
#   3. Emit `{}` — the hook contract's fail-open floor: Claude Code must
#      never see a hook block a tool call (exit 0, parseable stdout).
#
# stdin (the CC hook JSON payload) passes through exec to the real client.

set -uo pipefail

self_dir="$(cd "$(dirname "$0")" 2>/dev/null && pwd -P)"
plugin_root="${CLAUDE_PLUGIN_ROOT:-$(dirname "$self_dir")}"
node_client="${plugin_root}/dist/hook_client.js"

if command -v node >/dev/null 2>&1 && [ -f "$node_client" ]; then
  exec node "$node_client" "$@"
fi

if command -v agent-coherence-hook-client >/dev/null 2>&1; then
  exec agent-coherence-hook-client "$@"
fi

# Fail-open floor: no client available — degrade silently.
echo "{}"
exit 0
